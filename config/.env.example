# Exocortex Configuration File
# Copy this file to .env and fill in your values

# LLM API Key (required for automatic entity extraction)
# Get your key from https://platform.openai.com/api-keys
LLM_API_KEY=your_api_key_here

# LLM Model to use (default: gpt-4o-mini)
# Options: gpt-4, gpt-4o, gpt-4o-mini, gpt-3.5-turbo, etc.
LLM_MODEL=gpt-4o-mini

# Storage path for the knowledge graph (default: data/graph)
STORAGE_PATH=data/graph

# Optional: OpenAI API base URL (for compatible APIs)
# OPENAI_API_BASE=https://api.openai.com/v1
