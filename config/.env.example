# Exocortex Configuration File
# Copy this file to .env and fill in your values

# LLM provider: openai (default) or ollama for a local Ollama agent
LLM_PROVIDER=openai

# LLM API Key (optional for OpenAI-compatible providers; not needed for Ollama)
# Get your key from https://platform.openai.com/api-keys
LLM_API_KEY=

# LLM Model to use (default: gpt-4o-mini)
# Options: gpt-4, gpt-4o, gpt-4o-mini, llama3.1, qwen2.5, etc.
LLM_MODEL=gpt-4o-mini

# Storage path for the knowledge graph (default: data/graph)
STORAGE_PATH=data/graph

# Optional: OpenAI-compatible API base URL
# LLM_API_BASE=https://api.openai.com/v1
#
# OpenRouter example:
# LLM_API_BASE=https://openrouter.ai/api/v1
# LLM_MODEL=nvidia/nemotron-3-super-120b-a12b:free
#
# Local Ollama example:
# LLM_PROVIDER=ollama
# LLM_MODEL=llama3.1
# OLLAMA_BASE_URL=http://localhost:11434

# Compatible aliases also supported:
# OPENAI_API_KEY=
# OPENAI_API_BASE=https://api.openai.com/v1
